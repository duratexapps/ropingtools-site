/**
 * payments.jsw
 * Velo backend web module — event fee configuration, entry payment
 * (cash or online), producer payout profiles, cash-side execution
 * billing, and the partner-invite flow for lightweight team entries.
 *
 * Revenue rule: online and cash are mutually exclusive revenue paths.
 * Online — Draw Pro's cut + the processor's cut are charged ON TOP of
 * the entrant's fee, paid by the entrant; producer gets the full,
 * undiminished amount. Cash — entrant pays only the producer's stated
 * fee; Draw Pro is instead paid by the PRODUCER via an execution charge
 * (subscription or per-team, above a free threshold), since no money
 * moves through the platform to take a cut of.
 *
 * MERGED VERSION: this file combines the full fee/subscription/
 * execution-charge design built across several turns with Claude Chat
 * with the Wix-native email decision made independently on the Wix/
 * Velo side (see docs/ARCHITECTURE.md and data-collections/SCHEMA.md
 * for why: `elevate()` doesn't work as documented in this runtime,
 * which pushed everything toward Wix-native mechanisms where available
 * — Triggered Emails over an external ESP is one consequence of that,
 * not a competing design). Partner-invite emails below use Wix's
 * native Triggered Emails (wix-crm-backend) instead of SendGrid.
 *
 * ONLINE PROCESSOR: PayPal for Platforms, not Stripe — a deliberate
 * business decision, not a technical default. Reasoning: the near-term
 * target audience is small/mom-and-pop producers, who are far more
 * likely to already have (or know how to get) a PayPal account than a
 * Stripe account, which is largely invisible developer infrastructure
 * outside tech circles. Larger, already-automated producers (who may
 * prefer Stripe or their own existing tooling) are an explicitly later
 * target, once this is proven out with the smaller/lower-friction
 * audience first. See docs/ARCHITECTURE.md for the fuller discussion.
 *
 * PayPal for Platforms is a sales-application program, not instant
 * self-serve — RopingTools' application is in progress as of this
 * version. Everything below is structurally complete against PayPal's
 * documented Orders API v2 (purchase_units/payee/payment_instruction.
 * platform_fees) and Partner Referrals API v2, but NOT FUNCTIONAL until
 * that application is approved and real credentials exist in Secrets
 * Manager (drawpro-paypal-client-id, drawpro-paypal-client-secret,
 * drawpro-paypal-partner-merchant-id) — same "built but not live yet"
 * pattern already used elsewhere in this codebase (Triggered Email
 * template IDs, Stripe's now-replaced placeholder).
 *
 * Unlike Stripe's single-call payment_intents flow, PayPal's checkout is
 * inherently two-step and client-driven: create an order, the buyer
 * approves it (PayPal's JS SDK buttons or a redirect — not something
 * this backend module controls), then the platform captures it. That's
 * why processOnlinePayment() (one call) is now createPayPalOrder() +
 * capturePayPalOrder() (two calls) — not a stylistic change, a real
 * difference in how the two processors work. entrant-entry-form.js's
 * handlePayNow() has been updated to match; it still needs PayPal's JS
 * SDK buttons actually rendered on the page, which is real frontend work
 * not done here.
 *
 * PLATFORM_FEE_PERCENT/FLAT below are the CONFIRMED rate (4% + $1.50
 * flat) — not a placeholder as of this version. Processor rate,
 * per-team execution rate, free-team threshold, and subscription price
 * are still placeholders — see data-model.md for what's still unset.
 */

import wixData from 'wix-data';
import { fetch } from 'wix-fetch';
import { getSecret } from 'wix-secrets-backend';
import { currentMember } from 'wix-members-backend';
import { contacts, triggeredEmails } from 'wix-crm-backend';

const EVENTS = 'DrawProEvents';
const CLASSES = 'DrawProEventClasses';
const ENTRANTS = 'DrawProEntrants';
const TEAMS = 'DrawProTeams';
const PAYMENTS = 'DrawProPayments';
const PAYOUT_PROFILES = 'DrawProProducerPayoutProfiles';
const SUBSCRIPTIONS = 'DrawProProducerSubscriptions';
const EXECUTION_CHARGES = 'DrawProExecutionCharges';
const AUDIT_LOG = 'DrawProAuditLog';

// CONFIRMED — 4% + $1.50 flat, matching Steer Me's stated rate.
const PLATFORM_FEE_PERCENT = 0.04;
const PLATFORM_FEE_FLAT = 1.50;

// Placeholder — PayPal's real published rate belongs here once
// RopingTools' actual negotiated/standard rate is confirmed (PayPal for
// Platforms rates are negotiated per-partner, not a fixed public number
// the way Stripe's is — see the conversation that led to this choice).
const PROCESSOR_FEE_PERCENT = 0.029;
const PROCESSOR_FEE_FLAT = 0.30;

// Placeholders for the cash-side execution fee — from the pricing
// discussion, not yet finalized numbers.
const FREE_TEAM_THRESHOLD = 50; // teams per event before any charge applies
const PER_TEAM_EXECUTION_RATE = 0.50;

// SWITCH to https://api-m.sandbox.paypal.com while testing against a
// PayPal sandbox account, before the real application is approved.
const PAYPAL_API_BASE = 'https://api-m.paypal.com';
const PAYPAL_CLIENT_ID_SECRET_NAME = 'drawpro-paypal-client-id';
const PAYPAL_CLIENT_SECRET_SECRET_NAME = 'drawpro-paypal-client-secret';
// RopingTools' own PayPal partner/merchant ID, assigned once the PayPal
// for Platforms application is approved — used to look up a producer's
// onboarding status by tracking_id (see checkPayoutOnboardingStatus()).
const PAYPAL_PARTNER_MERCHANT_ID_SECRET_NAME = 'drawpro-paypal-partner-merchant-id';
// Where a producer lands back on Draw Pro after completing PayPal's own
// onboarding flow — the page there should call checkPayoutOnboardingStatus().
const PARTNER_REFERRAL_RETURN_URL = 'https://www.ropingtools.com/drawpro/payout-onboarding-complete';

// TODO: same one-time setup as backend/notifications.jsw and
// backend/qr-and-alerts.jsw — create this Triggered Email template
// (variables: inviterName, eventTitle) in the Wix dashboard, then set
// this to its real email ID. Until set, sendPartnerInvite() throws a
// clear "not configured" error instead of silently failing.
const PARTNER_INVITE_EMAIL_ID = null;

const ENTRY_BASE_URL = 'https://www.ropingtools.com/drawpro-enter';

/* ------------------------------------------------------------------ */
/* Fee calculation                                                     */
/* ------------------------------------------------------------------ */

/**
 * The producer's own stated fee for a given entry count — what they
 * receive, regardless of payment method. Pure linear rate — see the
 * interpretation note in data-model.md.
 */
export function calculateProducerFee(pricePerEntry, requestedEntryCount) {
    if (typeof pricePerEntry !== 'number' || pricePerEntry < 0) {
        throw new Error('Invalid pricePerEntry.');
    }
    if (!Number.isInteger(requestedEntryCount) || requestedEntryCount < 1) {
        throw new Error('requestedEntryCount must be a positive whole number.');
    }
    return round2(pricePerEntry * requestedEntryCount);
}

function calculatePlatformCut(producerAmount) {
    return round2(producerAmount * PLATFORM_FEE_PERCENT + PLATFORM_FEE_FLAT);
}

function calculateProcessorCut(chargeBase) {
    return round2(chargeBase * PROCESSOR_FEE_PERCENT + PROCESSOR_FEE_FLAT);
}

/**
 * What the ENTRANT actually pays, which differs by method. Cash: exactly
 * the producer's fee, nothing added. Online: the producer's fee plus
 * Draw Pro's cut plus the processor's cut, all itemized.
 */
export function calculateEntrantCharge(pricePerEntry, requestedEntryCount, paymentMethod) {
    const producerAmount = calculateProducerFee(pricePerEntry, requestedEntryCount);

    if (paymentMethod === 'cash') {
        return { producerAmount, drawProFee: null, processingFee: null, totalChargedToEntrant: producerAmount };
    }

    const drawProFee = calculatePlatformCut(producerAmount);
    // Processor typically charges on the full amount actually moving,
    // including the platform's own cut.
    const processingFee = calculateProcessorCut(producerAmount + drawProFee);
    const totalChargedToEntrant = round2(producerAmount + drawProFee + processingFee);

    return { producerAmount, drawProFee, processingFee, totalChargedToEntrant };
}

function round2(n) {
    return Math.round(n * 100) / 100;
}

/* ------------------------------------------------------------------ */
/* Producer payout profile — set up once, reused across all events     */
/* ------------------------------------------------------------------ */

export async function getPayoutProfile(producerId) {
    const result = await wixData.query(PAYOUT_PROFILES).eq('producerId', producerId).find();
    return result.items.length > 0 ? result.items[0] : null;
}

/**
 * Starts PayPal seller onboarding for the signed-in producer (Partner
 * Referrals API v2). Returns an actionUrl the producer must be sent to
 * (redirect or new tab) to complete PayPal's own signup/permission-grant
 * flow — this step genuinely can't happen inside Draw Pro's own pages,
 * since it's the producer authenticating directly with PayPal, the same
 * as any "Sign in with X"-style OAuth flow.
 *
 * tracking_id is the producer's own Wix member ID — used afterward to
 * look up their resulting PayPal merchant ID, since Partner Referrals
 * doesn't hand that back synchronously (see checkPayoutOnboardingStatus()).
 */
export async function startProducerPayoutOnboarding() {
    const member = await currentMember.getMember();
    if (!member) throw new Error('Must be signed in as a producer.');

    const accessToken = await getPayPalAccessToken();

    const response = await fetch(`${PAYPAL_API_BASE}/v2/customer/partner-referrals`, {
        method: 'POST',
        headers: {
            'Authorization': `Bearer ${accessToken}`,
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({
            tracking_id: member._id,
            partner_config_override: {
                return_url: PARTNER_REFERRAL_RETURN_URL
            },
            operations: [{
                operation: 'API_INTEGRATION',
                api_integration_preference: {
                    rest_api_integration: {
                        integration_method: 'PAYPAL',
                        integration_type: 'THIRD_PARTY',
                        third_party_details: {
                            features: ['PAYMENT', 'REFUND']
                        }
                    }
                }
            }],
            products: ['PPCP'],
            legal_consents: [{ type: 'SHARE_DATA_CONSENT', granted: true }]
        })
    });

    if (!response.ok) {
        throw new Error(`PayPal partner-referral request failed: ${response.status}`);
    }

    const data = await response.json();
    const actionUrlLink = (data.links || []).find(l => l.rel === 'action_url');
    if (!actionUrlLink) {
        throw new Error('PayPal did not return an onboarding action_url.');
    }

    const existing = await getPayoutProfile(member._id);
    const record = {
        producerId: member._id,
        payoutProvider: 'paypal',
        payoutAccountId: null, // filled in once onboarding completes, see below
        onboardingStatus: 'pending',
        payoutContactEmail: member.loginEmail || null
    };
    if (existing) {
        await wixData.update(PAYOUT_PROFILES, { ...existing, ...record });
    } else {
        await wixData.insert(PAYOUT_PROFILES, record);
    }

    return { actionUrl: actionUrlLink.href };
}

/**
 * Fallback path for confirming onboarding completion: call this from the
 * page a producer lands back on after PayPal's own flow (see
 * PARTNER_REFERRAL_RETURN_URL above). Looks up their merchant status by
 * the tracking_id (their Wix member ID) via PayPal's merchant-integrations
 * endpoint and marks the profile complete once PayPal confirms payments
 * are receivable.
 *
 * The more real-time way to catch this is PayPal's own
 * MERCHANT.ONBOARDING.COMPLETED webhook — NOT YET BUILT. When it is, it
 * belongs in backend/http-functions.js (same pattern as
 * post_joinDrawProWaitlist) and should call completePayoutOnboarding()
 * below directly rather than duplicating this lookup logic.
 */
export async function checkPayoutOnboardingStatus(producerId) {
    const accessToken = await getPayPalAccessToken();
    const partnerId = await getSecret(PAYPAL_PARTNER_MERCHANT_ID_SECRET_NAME);
    if (!partnerId) {
        throw new Error('PayPal partner merchant ID is not configured yet — see backend/payments.jsw setup note.');
    }

    const response = await fetch(
        `${PAYPAL_API_BASE}/v1/customer/partners/${partnerId}/merchant-integrations?tracking_id=${encodeURIComponent(producerId)}`,
        { headers: { 'Authorization': `Bearer ${accessToken}` } }
    );

    if (!response.ok) {
        throw new Error(`PayPal merchant-integration lookup failed: ${response.status}`);
    }

    const data = await response.json();
    if (data.payments_receivable === true && data.merchant_id) {
        return completePayoutOnboarding(producerId, data.merchant_id);
    }

    return getPayoutProfile(producerId); // still pending — nothing to update yet
}

/**
 * Marks a producer's payout profile complete with their real PayPal
 * merchant ID. Called from checkPayoutOnboardingStatus() above, or from
 * the MERCHANT.ONBOARDING.COMPLETED webhook once that's built. Only
 * after this can the producer pick paymentMethod: 'online' on an event —
 * createPayPalOrder() below checks onboardingStatus === 'complete'.
 */
export async function completePayoutOnboarding(producerId, merchantId) {
    const profile = await getPayoutProfile(producerId);
    if (!profile) throw new Error('No payout profile found for this producer.');
    return wixData.update(PAYOUT_PROFILES, {
        ...profile,
        payoutAccountId: merchantId,
        onboardingStatus: 'complete'
    });
}

/* ------------------------------------------------------------------ */
/* Recording an entry's fee at submission time                         */
/* ------------------------------------------------------------------ */

/**
 * Called from event-setup.jsw's submitEntry() right after an entrant
 * record is created — snapshots what the PRODUCER'S fee is (before any
 * online markup, which is calculated separately at payment time since
 * it only applies if/when the entrant actually pays online) and sets
 * initial payment status based on the event's paymentMethod.
 *
 * Uses pricePerPreformedTeamEntry for team entries (the Steer Me
 * incentive rate) and pricePerEntry for solo/draw-in entries.
 *
 * NOTE: event-setup.jsw's current submitEntry() sets feeOwed directly
 * on the entrant record at insert time (via calculateProducerFee(),
 * exported above) rather than inserting bare and calling this function
 * as a second step — both approaches compute the identical number, this
 * one is just left available for a flow that inserts first and sets the
 * fee after (e.g. scan-import's OCR path, if it ends up needing that
 * shape).
 */
export async function initializeEntryFee(eventId, entrantId, requestedEntryCount) {
    const event = await wixData.get(EVENTS, eventId);
    const entrant = await wixData.get(ENTRANTS, entrantId);

    const rate = entrant.entryType === 'preformed_team'
        ? (event.pricePerPreformedTeamEntry || event.pricePerEntry)
        : event.pricePerEntry;

    const feeOwed = calculateProducerFee(rate, requestedEntryCount);
    const initialStatus = event.paymentMethod === 'cash' ? 'pending_cash' : 'unpaid';

    return wixData.update(ENTRANTS, {
        ...entrant,
        requestedEntryCount,
        feeOwed,
        paymentStatus: initialStatus
    });
}

/* ------------------------------------------------------------------ */
/* Cash payments — confirmed by producer/staff at the event            */
/* ------------------------------------------------------------------ */

/**
 * Producer/staff marks a cash payment received. No processor or
 * platform cut applies — the producer collects and keeps it directly,
 * Draw Pro just records that it happened.
 */
export async function recordCashPayment(eventId, entrantId) {
    const member = await currentMember.getMember();
    if (!member) throw new Error('Must be signed in as the producer or event staff.');

    const entrant = await wixData.get(ENTRANTS, entrantId);
    if (entrant.eventId !== eventId) throw new Error('Entrant does not belong to this event.');
    if (entrant.paymentStatus === 'paid') throw new Error('This entry is already marked paid.');

    const referenceNumber = generateReferenceNumber();

    await wixData.update(ENTRANTS, {
        ...entrant,
        paymentStatus: 'paid',
        paymentReferenceNumber: referenceNumber
    });

    await wixData.insert(PAYMENTS, {
        eventId,
        entrantId,
        producerAmount: entrant.feeOwed,
        drawProFee: null,
        processingFee: null,
        totalChargedToEntrant: entrant.feeOwed,
        netToProducer: entrant.feeOwed,
        method: 'cash',
        referenceNumber,
        providerTransactionId: null,
        status: 'completed',
        timestamp: new Date()
    });

    await wixData.insert(AUDIT_LOG, {
        eventId,
        actionType: 'payment_recorded',
        performedByUserId: member._id,
        timestamp: new Date(),
        detail: `Recorded cash payment of $${entrant.feeOwed.toFixed(2)} from ` +
                 `${entrant.firstName} ${entrant.lastName}. Reference ${referenceNumber}.`
    });

    return { referenceNumber };
}

/**
 * Whether an event's draw sheet is safe to finalize given cash-payment
 * status — "not final until funds are received prior to closing of the
 * books." Called from matching-engine.jsw's finalizeDrawSheet.
 */
export async function getUnpaidCashEntrants(eventId) {
    const result = await wixData.query(ENTRANTS)
        .eq('eventId', eventId)
        .eq('paymentStatus', 'pending_cash')
        .find();
    return result.items;
}

/* ------------------------------------------------------------------ */
/* Online payments                                                     */
/* ------------------------------------------------------------------ */

/**
 * Gets a PayPal OAuth2 access token via the client-credentials grant.
 * Buffer is assumed available in Velo's backend Node runtime for the
 * base64 Basic-auth header (common in other Velo/Stripe integration
 * snippets) — NOT yet live-tested against Velo specifically; if this
 * errors in practice, swap in a manual base64 helper, same as how the
 * postMessage bridge and elevate() platform gaps were discovered
 * elsewhere in this codebase (see docs/ARCHITECTURE.md) — verify live
 * rather than assume.
 */
async function getPayPalAccessToken() {
    const clientId = await getSecret(PAYPAL_CLIENT_ID_SECRET_NAME);
    const clientSecret = await getSecret(PAYPAL_CLIENT_SECRET_SECRET_NAME);
    if (!clientId || !clientSecret) {
        throw new Error('PayPal is not configured yet — no Client ID/Secret in Secrets Manager. See backend/payments.jsw setup note.');
    }

    const basicAuth = Buffer.from(`${clientId}:${clientSecret}`).toString('base64');
    const response = await fetch(`${PAYPAL_API_BASE}/v1/oauth2/token`, {
        method: 'POST',
        headers: {
            'Authorization': `Basic ${basicAuth}`,
            'Content-Type': 'application/x-www-form-urlencoded'
        },
        body: 'grant_type=client_credentials'
    });

    if (!response.ok) {
        throw new Error(`PayPal auth failed: ${response.status}`);
    }
    const data = await response.json();
    return data.access_token;
}

/**
 * Step 1 of PayPal's two-step checkout: create the order with the split
 * already specified (purchase_units.payee = the producer's own PayPal
 * merchant account, purchase_units.payment_instruction.platform_fees =
 * Draw Pro's + the processor's cut). Returns the orderId the frontend
 * needs to render PayPal's approval buttons/redirect — nothing is
 * charged yet. disbursementMode defaults to INSTANT (funds settle to
 * the producer immediately on capture); DELAYED is the alternative if a
 * risk/dispute holding period is ever wanted instead — not decided here,
 * flagging as a real option rather than assuming INSTANT is final.
 */
export async function createPayPalOrder(eventId, entrantId) {
    const event = await wixData.get(EVENTS, eventId);
    const entrant = await wixData.get(ENTRANTS, entrantId);
    const cls = await wixData.get(CLASSES, entrant.classId);

    if (event.paymentMethod !== 'online') {
        throw new Error('This event is not set up for online payment.');
    }
    if (entrant.paymentStatus === 'paid') {
        throw new Error('This entry has already been paid.');
    }

    const producerProfile = await getPayoutProfile(event.producerId);
    if (!producerProfile || producerProfile.onboardingStatus !== 'complete' || !producerProfile.payoutAccountId) {
        throw new Error('This producer has not finished payout setup — online payment is unavailable for this event.');
    }

    // UPDATED for the multi-class redesign: rate now comes from the
    // entrant's class, not the event. Also now applies drawInSurchargeFee
    // for solo/draw-in entries — this was missing even before the
    // redesign (the old code only ever distinguished preformed vs solo
    // rate, never added the draw-in surcharge on top), caught while
    // fixing this function for classId, not a separate pass.
    const rate = entrant.entryType === 'preformed_team'
        ? (cls.pricePerPreformedTeamEntry || cls.pricePerEntry)
        : cls.pricePerEntry + (cls.drawInSurchargeFee || 0);

    const { producerAmount, drawProFee, processingFee, totalChargedToEntrant } =
        calculateEntrantCharge(rate, entrant.requestedEntryCount, 'online');
    const platformRetained = round2(drawProFee + processingFee);

    const accessToken = await getPayPalAccessToken();

    const response = await fetch(`${PAYPAL_API_BASE}/v2/checkout/orders`, {
        method: 'POST',
        headers: {
            'Authorization': `Bearer ${accessToken}`,
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({
            intent: 'CAPTURE',
            purchase_units: [{
                reference_id: entrantId,
                amount: {
                    currency_code: 'USD',
                    value: totalChargedToEntrant.toFixed(2)
                },
                payee: {
                    merchant_id: producerProfile.payoutAccountId
                },
                payment_instruction: {
                    disbursement_mode: 'INSTANT',
                    platform_fees: [{
                        amount: {
                            currency_code: 'USD',
                            value: platformRetained.toFixed(2)
                        }
                    }]
                }
            }]
        })
    });

    if (!response.ok) {
        throw new Error(`PayPal order creation failed: ${response.status}`);
    }

    const data = await response.json();

    // Stash the computed charge breakdown against the entrant now, so
    // capturePayPalOrder() doesn't have to recompute it (and risk it
    // drifting if pricing changes between order creation and capture —
    // this way capture always uses exactly what the entrant approved).
    await wixData.update(ENTRANTS, {
        ...entrant,
        pendingPayPalOrderId: data.id,
        pendingCharge: { producerAmount, drawProFee, processingFee, totalChargedToEntrant }
    });

    return { orderId: data.id, totalChargedToEntrant };
}

/**
 * Step 2: called once the buyer has approved the order client-side
 * (PayPal's JS SDK onApprove callback — not built here, see
 * entrant-entry-form.js). Captures the funds; PayPal handles the actual
 * split (producer's connected account + Draw Pro's platform fee) as
 * part of this same call, per how platform_fees works in the Orders API.
 */
export async function capturePayPalOrder(eventId, entrantId, orderId) {
    const entrant = await wixData.get(ENTRANTS, entrantId);

    if (entrant.paymentStatus === 'paid') {
        throw new Error('This entry has already been paid.');
    }
    if (entrant.pendingPayPalOrderId !== orderId) {
        throw new Error('This order does not match the pending order for this entrant.');
    }

    const { producerAmount, drawProFee, processingFee, totalChargedToEntrant } = entrant.pendingCharge;
    const accessToken = await getPayPalAccessToken();

    const response = await fetch(`${PAYPAL_API_BASE}/v2/checkout/orders/${orderId}/capture`, {
        method: 'POST',
        headers: {
            'Authorization': `Bearer ${accessToken}`,
            'Content-Type': 'application/json'
        }
    });

    if (!response.ok) {
        throw new Error(`PayPal capture failed: ${response.status}`);
    }

    const data = await response.json();
    const capture = data.purchase_units && data.purchase_units[0] &&
        data.purchase_units[0].payments && data.purchase_units[0].payments.captures &&
        data.purchase_units[0].payments.captures[0];

    if (!capture || capture.status !== 'COMPLETED') {
        throw new Error('PayPal did not confirm the capture completed.');
    }

    const referenceNumber = generateReferenceNumber();

    await wixData.update(ENTRANTS, {
        ...entrant,
        feeOwed: producerAmount,
        paymentStatus: 'paid',
        paymentReferenceNumber: referenceNumber,
        pendingPayPalOrderId: null,
        pendingCharge: null
    });

    await wixData.insert(PAYMENTS, {
        eventId,
        entrantId,
        producerAmount,
        drawProFee,
        processingFee,
        totalChargedToEntrant,
        netToProducer: producerAmount,
        method: 'online',
        referenceNumber,
        providerTransactionId: capture.id,
        status: 'completed',
        timestamp: new Date()
    });

    return { referenceNumber, amountCharged: totalChargedToEntrant, producerAmount, drawProFee, processingFee };
}

function generateReferenceNumber() {
    // Human-readable confirmation code, not a security token.
    const stamp = Date.now().toString(36).toUpperCase();
    const rand = Math.floor(Math.random() * 1296).toString(36).toUpperCase().padStart(2, '0');
    return `DP-${stamp}-${rand}`;
}

/* ------------------------------------------------------------------ */
/* Producer subscriptions — optional, covers cash-event execution fees */
/* ------------------------------------------------------------------ */

export async function getSubscription(producerId) {
    const result = await wixData.query(SUBSCRIPTIONS).eq('producerId', producerId).find();
    return result.items.length > 0 ? result.items[0] : null;
}

async function hasActiveSubscription(producerId) {
    const sub = await getSubscription(producerId);
    return !!(sub && sub.status === 'active' && (!sub.renewalDate || new Date(sub.renewalDate) > new Date()));
}

/**
 * Starts (or renews) a producer's annual subscription. annualFee is
 * passed in explicitly rather than hardcoded here — real pricing isn't
 * finalized, so the caller (an admin tool or a future pricing page)
 * supplies whatever the current published rate is.
 */
export async function subscribeToAnnualPlan(producerId, annualFee) {
    const existing = await getSubscription(producerId);
    const now = new Date();
    const renewalDate = new Date(now);
    renewalDate.setFullYear(renewalDate.getFullYear() + 1);

    const record = {
        producerId,
        status: 'active',
        annualFee,
        startDate: now,
        renewalDate
    };

    if (existing) {
        return wixData.update(SUBSCRIPTIONS, { ...existing, ...record });
    }
    return wixData.insert(SUBSCRIPTIONS, record);
}

export async function cancelSubscription(producerId) {
    const existing = await getSubscription(producerId);
    if (!existing) return null;
    return wixData.update(SUBSCRIPTIONS, { ...existing, status: 'expired' });
}

/* ------------------------------------------------------------------ */
/* Cash-event execution charge — how Draw Pro gets paid on cash events  */
/* ------------------------------------------------------------------ */

/**
 * Called once a CASH-method event's draw executes (from
 * matching-engine.jsw's executeDraw, only when event.paymentMethod ===
 * 'cash'). Calculates what the producer owes for running the draw —
 * $0 if covered by an active subscription or under the free threshold,
 * otherwise billableTeamCount x PER_TEAM_EXECUTION_RATE. This function
 * only calculates and logs the charge; actually collecting it from the
 * producer needs its own billing flow, not yet built (see data-model.md).
 *
 * UPDATED for the multi-class redesign (2026-07-21, see
 * docs/ARCHITECTURE.md): scoped to classId now, not eventId — each class
 * draws (and so incurs this charge) independently. matching-engine.jsw's
 * executeDraw calls this with classId once teams are persisted for that
 * class.
 *
 * Only teams the matching ALGORITHM paired count toward the billable
 * total — pre-formed teams (Steer Me matches, or any two people who
 * chose each other) required no computational work, so they're free
 * regardless of subscription status. This is deliberate: it gives
 * producers a direct financial reason to want more of their field
 * pre-formed via Steer Me, not just a values-based nudge.
 */
export async function calculateAndRecordExecutionCharge(classId) {
    const cls = await wixData.get(CLASSES, classId);
    const event = await wixData.get(EVENTS, cls.eventId);
    if (event.paymentMethod !== 'cash') {
        return null; // online events never generate an execution charge
    }

    const teamCount = await wixData.query(TEAMS).eq('classId', classId).count();
    const matchedTeamCount = await wixData.query(TEAMS).eq('classId', classId).eq('preFormed', false).count();
    const covered = await hasActiveSubscription(event.producerId);

    const billableTeamCount = Math.max(0, matchedTeamCount - FREE_TEAM_THRESHOLD);
    const amountDue = covered ? 0 : round2(billableTeamCount * PER_TEAM_EXECUTION_RATE);

    const record = {
        eventId: cls.eventId,
        classId,
        producerId: event.producerId,
        teamCount,
        matchedTeamCount,
        freeThreshold: FREE_TEAM_THRESHOLD,
        billableTeamCount,
        perTeamRate: covered ? null : PER_TEAM_EXECUTION_RATE,
        coveredBySubscription: covered,
        amountDue,
        status: amountDue === 0 ? 'no_charge' : 'pending',
        timestamp: new Date()
    };

    const saved = await wixData.insert(EXECUTION_CHARGES, record);

    if (amountDue > 0) {
        await wixData.insert(AUDIT_LOG, {
            eventId: cls.eventId,
            classId,
            actionType: 'payment_recorded',
            performedByUserId: event.producerId,
            timestamp: new Date(),
            detail: `Execution charge of $${amountDue.toFixed(2)} logged for ${matchedTeamCount} algorithm-matched teams ` +
                     `(${teamCount - matchedTeamCount} pre-formed teams excluded; ${billableTeamCount} billable above the ` +
                     `${FREE_TEAM_THRESHOLD}-team free threshold). Not yet collected — no producer billing method on file.`
        });
    }

    return saved;
}

/* ------------------------------------------------------------------ */
/* Lightweight team entry — partner invite by email                    */
/* ------------------------------------------------------------------ */

/**
 * Sends a "you've been entered — claim your info" email to a partner
 * whose full details weren't collected at entry time, only their
 * email. Growth mechanic: surfaces RopingTools to someone who may not
 * have an account, tied to a real, specific reason to click through.
 *
 * Uses Wix Triggered Emails (see file header) — call
 * contacts.appendOrCreateContact() to resolve/create a Contact for the
 * partner's raw email, then email that contact ID, since emailContact()
 * needs a contact ID, not a raw address, and a partner invited this way
 * won't already be a Wix Contact in the common case.
 */
export async function sendPartnerInvite(entrantId) {
    if (!PARTNER_INVITE_EMAIL_ID) {
        throw new Error('Partner invite email template is not configured yet — see backend/payments.jsw setup note.');
    }

    const entrant = await wixData.get(ENTRANTS, entrantId);
    if (!entrant.partnerEmailOnly) {
        throw new Error('This entrant does not have a pending partner invite.');
    }

    const event = await wixData.get(EVENTS, entrant.eventId);

    const { contactId } = await contacts.appendOrCreateContact({
        emails: [{ email: entrant.partnerEmailOnly }]
    });

    await triggeredEmails.emailContact(PARTNER_INVITE_EMAIL_ID, contactId, {
        variables: {
            inviterName: `${entrant.firstName} ${entrant.lastName}`,
            eventTitle: event.title
        }
    });

    return wixData.update(ENTRANTS, { ...entrant, partnerInviteStatus: 'sent' });
}

/**
 * Called when the invited partner follows the claim link and fills in
 * their own info — creates their entrant record and links it back,
 * same as a normal pre-formed team entry from that point forward.
 */
export async function claimPartnerInvite(originalEntrantId, partnerDetails) {
    const original = await wixData.get(ENTRANTS, originalEntrantId);
    if (!original.partnerEmailOnly) {
        throw new Error('No pending partner invite for this entry.');
    }

    const partnerRole = original.role === 'header' ? 'heeler' : 'header';
    const partnerRecord = {
        eventId: original.eventId,
        classId: original.classId,
        submissionGroupId: original.submissionGroupId,
        firstName: partnerDetails.firstName,
        lastName: partnerDetails.lastName,
        classificationNumber: partnerDetails.classificationNumber,
        globalMembershipId: partnerDetails.globalMembershipId || null,
        email: original.partnerEmailOnly,
        phone: partnerDetails.phone || null,
        role: partnerRole,
        entryType: 'preformed_team',
        teamPartnerEntrantId: original._id,
        partnerEmailOnly: null,
        partnerInviteStatus: null,
        isGuestEntry: !!partnerDetails.isGuestEntry,
        guestContactHash: null,
        source: 'self_entry',
        scanVerified: false,
        requestedEntryCount: original.requestedEntryCount,
        feeOwed: original.feeOwed,
        isFeeResponsible: false, // original entrant already owns the team fee
        paymentStatus: original.paymentStatus,
        paymentReferenceNumber: original.paymentReferenceNumber,
        entryTimestamp: new Date()
    };

    const savedPartner = await wixData.insert(ENTRANTS, partnerRecord);

    await wixData.update(ENTRANTS, {
        ...original,
        teamPartnerEntrantId: savedPartner._id,
        partnerEmailOnly: null,
        partnerInviteStatus: 'claimed'
    });

    return savedPartner;
}

// buildEntryUrl kept for parity with qr-and-alerts.jsw's entry-link
// pattern, used if a claim-link builder is needed from outside this
// module (e.g. a producer resending an invite manually).
export function buildClaimUrl(eventId, entrantId) {
    return `${ENTRY_BASE_URL}?event=${eventId}&claim=${entrantId}`;
}
